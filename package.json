{
  "name": "signwell-cli",
  "version": "1.0.0",
  "description": "A top-tier Node.js CLI for the SignWell eSignature API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "bin": {
    "sw": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "signwell",
    "esignature",
    "cli",
    "document-signing",
    "e-signature",
    "signing",
    "api"
  ],
  "author": "Zachary Oakes <zachary.oakes@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bidsketch/signwell-cli.git"
  },
  "homepage": "https://github.com/Bidsketch/signwell-cli#readme",
  "bugs": {
    "url": "https://github.com/Bidsketch/signwell-cli/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "1.16.1",
    "axios-retry": "4.5.0",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "csv-parse": "5.6.0",
    "inquirer": "9.3.8",
    "mime-types": "2.1.35",
    "ora": "8.2.0",
    "yargs": "17.7.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/inquirer": "9.0.9",
    "@types/mime-types": "2.1.4",
    "@types/node": "20.19.35",
    "@types/yargs": "17.0.35",
    "nock": "13.5.6",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "overrides": {
    "follow-redirects": "1.16.0",
    "picomatch": "4.0.4",
    "postcss": "8.5.10",
    "vite": "6.4.2"
  }
}
